# Copy to .env and fill in values. Never commit .env.

# Model strings — pinned in config.py; override here only to test preview models
REASONING_MODEL=gemini-3.1-pro-preview
FAST_MODEL=gemini-3.5-flash
SESSION_PREP_MODEL=gemini-3.1-flash-lite
TURN_RATING_MODEL=gemini-3.1-flash-lite

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_API_KEY=

# Gemini Live voice mode
LIVE_AUDIO_MODEL=models/gemini-3.1-flash-live-preview
LIVE_AUDIO_VOICE=Zephyr
LIVE_AUDIO_DEBUG=false

# Perplexity — server-side only, NEVER shipped to web/
PERPLEXITY_API_KEY=
ALLOWED_SOURCES_PATH=crucible/grounding/allowed_sources.yaml

# Neo4j (local Docker via `make neo4j`)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embeddings
EMBED_MODEL=text-embedding-004
EMBED_DIM=768

# Optional — defaults to TURN_RATING_MODEL if unset
ENTAILMENT_MODEL=

# Feature flags
OPPONENT_SPOT_THE_BAD_CITATION=false
